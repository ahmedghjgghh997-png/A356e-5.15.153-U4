# ========== تعطيل جميع حمايات سامسونج ==========
CONFIG_UH=n
CONFIG_UH_RKP=n
CONFIG_RKP_CFP=n
CONFIG_RKP_CFP_JOPP=n
CONFIG_UH_LKMAUTH=n
CONFIG_UH_LKM_BLOCK=n
CONFIG_SECURITY_DEFEX=n
CONFIG_PROCA=n
CONFIG_FIVE=n
CONFIG_TIMA=n
CONFIG_TIMA_LKMAUTH=n
CONFIG_KNOX_KAP=n
CONFIG_SEC_RESTRICT_ROOTING=n
CONFIG_SEC_RESTRICT_SETUID=n
CONFIG_SEC_RESTRICT_FORK=n
CONFIG_INTEGRITY=n
CONFIG_DM_VERITY=n

# ========== تعطيل التوقيعات (لتجنب رفض الوحدات) ==========
CONFIG_MODULE_SIG=n
CONFIG_MODULE_SIG_FORCE=n
CONFIG_MODULE_SIG_ALL=n

# ========== جعل SELinux permissive (ضروري لـ KernelSU) ==========
CONFIG_SECURITY_SELINUX_DEVELOP=y
CONFIG_SECURITY_SELINUX_ALWAYS_PERMISSIVE=y
CONFIG_SECURITY_SELINUX_ALWAYS_ENFORCE=n

# ========== تفعيل KPROBES (لـ KernelSU) ==========
CONFIG_KPROBES=y
CONFIG_HAVE_KPROBES=y
CONFIG_KPROBE_EVENTS=y

# ========== استخدام ضغط gzip للنواة (إذا كان جهازك لا يقبل Image الخام) ==========
CONFIG_KERNEL_GZIP=y

# ========== تحسينات إضافية ==========
CONFIG_LOCALVERSION_AUTO=n
CONFIG_DEBUG_INFO=n
CONFIG_DEBUG_INFO_BTF=n
